#!/bin/bash

# Automatically sets up your devbox environment whenever you cd into this
# directory via our direnv integration:

eval "$(devbox generate direnv --print-envrc)"

# Ensure venv bin is first in PATH (more reliable than source activate in direnv)
if [ -d "$VENV_DIR/bin" ]; then
    # Remove venv bin from PATH if already present, then prepend
    PATH="$(echo "$PATH" | tr ':' '\n' | grep -v "^$VENV_DIR/bin$" | tr '\n' ':' | sed 's/:$//')"
    export PATH="$VENV_DIR/bin:$PATH"
fi

# check out https://www.jetify.com/docs/devbox/ide_configuration/direnv/
# for more details
